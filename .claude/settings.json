{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_BASH_NO_LOGIN": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "true",
    "CLAUDE_CODE_SHELL": "/usr/bin/zsh",
    "CLAUDE_CODE_SIMPLE": "false",
    "DISABLE_AUTOUPDATER": "0",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "attribution": {
    "commit": "commit yao",
    "pr": "pr yao"
  },
  "permissions": {
    "allow": [
      "Bash(wc -l .planning/codebase/*.md)",
      "Bash(gita *)",
      "Bash(gptodo *)",
      "Bash(gh *)",
      "Bash(skogai *)",
      "Bash(argc *)",
      "Bash(skogcli *)",
      "Skill(skogai-routing:*)",
      "Skill(skogai-bats-testing:*)",
      "Bash(wt *)",
      "Bash(rtk ls *)",
      "Bash(rtk git *)",
      "Bash(rtk read *)",
      "Skill(codex:rescue)",
      "Skill(codex:rescue:*)",
      "WebFetch(domain:api.anthropic.com)",
      "Bash(rtk find *)",
      "Bash(rtk curl *)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook claude-code || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".skogai/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook claude-code || true"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook claude-code || true"
          }
        ]
      }
    ]
  },
  "disableAllHooks": false,
  "statusLine": {
    "type": "command",
    "command": "command -v wt >/dev/null 2>&1 && wt list statusline --format=claude-code || git rev-parse --abbrev-ref HEAD 2>/dev/null || true"
  },
  "enabledPlugins": {
    "skogai-caveman@skogai-marketplace": true
  },
  "extraKnownMarketplaces": {
    "skogai-marketplace": {
      "source": {
        "source": "git",
        "url": "git@github.com:SkogAI/marketplace.git"
      },
      "autoUpdate": true
    }
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "tips": [
      "Analyzing the codebase... :mag:",
      "Formulating a plan... :brain:",
      "Executing the plan... :rocket:",
      "Reviewing results... :eyes:",
      "Consulting the drug database... :pill:",
      "Evaluating drug interactions... :microscope:",
      "Formulating treatment plan... :brain:",
      "Reviewing medical guidelines... :book:"
    ]
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "advisorModel": "opus",
  "plansDirectory": "~/claude/.skogai/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": "~/claude/.skogai/memory",
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "defaultView": "transcript",
  "teammateMode": "tmux"
}
