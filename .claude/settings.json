{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_BASH_NO_LOGIN": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "true",
    "CLAUDE_CODE_SHELL": "/usr/bin/zsh",
    "CLAUDE_CODE_SIMPLE": "false",
    "DISABLE_AUTOUPDATER": "0",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Bash(wc -l .planning/codebase/*.md)",
      "Bash(gita *)",
      "Bash(gptodo *)",
      "Bash(gh *)",
      "Bash(skogai *)",
      "Bash(argc *)",
      "Bash(skogcli *)",
      "Skill(skogai-routing:*)",
      "Skill(skogai-bats-testing:*)",
      "Bash(wt *)",
      "Bash(rtk ls *)",
      "Bash(rtk git *)",
      "Bash(rtk read *)",
      "Skill(codex:rescue)",
      "Skill(codex:rescue:*)",
      "WebFetch(domain:api.anthropic.com)",
      "Bash(rtk find *)",
      "Bash(rtk curl *)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/claude-todo/bin/claude-md-linecheck",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f && [ -n \"$f\" ] && npx prettier --write --ignore-unknown \"$f\"; } 2>/dev/null || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [ -z \"$f\" ] && exit 0; [[ \"$f\" == *.sh || \"$f\" == */bin/* ]] || exit 0; command -v shellcheck >/dev/null 2>&1 || exit 0; shellcheck \"$f\" || true",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook claude-code || true"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook claude-code || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook claude-code || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".skogai/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "out=$(\"$CLAUDE_PROJECT_DIR\"/claude-todo/bin/healthcheck 2>&1); code=$?; if [ \"$code\" -ne 0 ]; then jq -nc --arg m \"$out\" '{\"systemMessage\":\"\u26a0 healthcheck failed\\n\\($m)\"}'; fi",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "disableAllHooks": false,
  "statusLine": {
    "type": "command",
    "command": "command -v wt >/dev/null 2>&1 && wt list statusline --format=claude-code || git rev-parse --abbrev-ref HEAD 2>/dev/null || true"
  },
  "enabledPlugins": {
    "core@skogai-marketplace": false,
    "dreamers@skogai-marketplace": false,
    "frontend-design@claude-plugins-official": false,
    "worktrunk@worktrunk": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "skogai-marketplace": {
      "source": {
        "source": "git",
        "url": "git@github.com:SkogAI/marketplace.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "spinnerTipsEnabled": true,
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "advisorModel": "opus",
  "autoMemoryDirectory": "~/claude/.skogai/memory",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "defaultView": "transcript"
}
