{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 90,
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_TMPDIR": "/home/skogix/claude/tmp",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "DISABLE_AUTOUPDATER": "0",
    "CLAUDE_CODE_SIMPLE": "false",
    "CLAUDE_CODE_SHELL": "/usr/bin/zsh",
    "CLAUDE_BASH_NO_LOGIN": "1",
    "CLAUDE_CODE_NEW_INIT": "true"
  },
  "permissions": {
    "allow": [
      "mcp__skogchat__reply",
      "Skill(gsd:new-project)",
      "Skill(gsd:new-project:*)",
      "Bash(wc -l .planning/codebase/*.md)",
      "Bash(gita *)",
      "Bash(gptodo *)",
      "Bash(gh *)",
      "Bash(skogai *)",
      "Bash(argc *)",
      "Bash(skogcli *)",
      "Skill(gsd:*)",
      "Skill(skogai-routing:*)",
      "Skill(skogai-bats-testing:*)",
      "Bash(wt *)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/home/skogix/claude/"
    ]
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/skogix/claude/bin/claude-md-linecheck",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "disableAllHooks": false,
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "directory",
        "path": "/home/skogix/.local/src/worktrunk"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "skogai-marketplace": {
      "source": {
        "source": "directory",
        "path": "/home/skogix/.local/src/marketplace"
      },
      "autoUpdate": true
    }
  },
  "spinnerTipsEnabled": true,
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "defaultView": "transcript",
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": "/home/skogix/claude/.planning/memory",
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
